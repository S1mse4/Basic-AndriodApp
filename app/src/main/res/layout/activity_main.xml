<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Header / Portfolio Summary -->
    <LinearLayout
        android:id="@+id/headerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:padding="@dimen/padding_header"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvDayCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Day 0"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_small"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTotalValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$10,000.00"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_hero"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCashBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cash: $10,000.00"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold"
                android:gravity="end" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvHoldingsValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Invested: $0.00"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTotalChange"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="P&amp;L: +$0.00"
                android:textColor="@color/stock_green"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold"
                android:gravity="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Market Section -->
    <LinearLayout
        android:id="@+id/marketSection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/header_height"
        android:layout_marginBottom="@dimen/bottom_nav_height"
        android:orientation="vertical">

        <!-- Sort bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/bg_card"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sort:"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_small"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <Spinner
                android:id="@+id/spinnerSort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@color/spinner_popup_bg"
                android:popupBackground="@color/spinner_popup_bg" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMarket"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <!-- Portfolio Section -->
    <LinearLayout
        android:id="@+id/portfolioSection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/header_height"
        android:layout_marginBottom="@dimen/bottom_nav_height"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvEmptyPortfolio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No holdings yet.\nGo to Market and buy some shares!"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="60dp"
            android:padding="24dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPortfolio"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

        <!-- Combined Holdings Chart -->
        <LinearLayout
            android:id="@+id/combinedChartSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_card"
            android:padding="@dimen/padding_item"
            android:layout_marginTop="2dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMBINED PERFORMANCE"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_micro"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp" />

            <com.example.basicandroidapp.ui.CombinedStockChartView
                android:id="@+id/combinedChart"
                android:layout_width="match_parent"
                android:layout_height="@dimen/combined_chart_height" />

        </LinearLayout>

    </LinearLayout>

    <!-- Player Data Section -->
    <ScrollView
        android:id="@+id/playerSection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/header_height"
        android:layout_marginBottom="@dimen/bottom_nav_height"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_card">

            <!-- Biggest Single-Share Profit Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_card"
                android:padding="@dimen/padding_card"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEST SINGLE-SHARE PROFIT"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_micro"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvBiggestProfit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+$0.00"
                    android:textColor="@color/stock_green"
                    android:textSize="@dimen/text_size_display"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All-time highest unrealized profit per share (without selling)"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_small"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- All-time Portfolio Values Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_card"
                android:padding="@dimen/padding_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HIGHEST PORTFOLIO VALUE"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_micro"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvPortfolioHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No data yet — values are recorded each update."
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_headline"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All-time highest total portfolio value recorded"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_small"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bank Section -->
    <ScrollView
        android:id="@+id/bankSection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/header_height"
        android:layout_marginBottom="@dimen/bottom_nav_height"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_card">

            <!-- Deposit Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_card"
                android:padding="@dimen/padding_card"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAVINGS DEPOSIT"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_micro"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvBankDeposit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="@color/stock_green"
                    android:textSize="@dimen/text_size_headline"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Earns 0.1% interest per market tick"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_small"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etBankAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Amount"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:background="@color/bg_surface"
                    android:padding="@dimen/padding_input"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnDeposit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="DEPOSIT"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@color/stock_green"
                        android:layout_marginEnd="4dp" />

                    <Button
                        android:id="@+id/btnWithdraw"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="WITHDRAW"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@color/accent_blue"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnWithdrawAll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WITHDRAW ALL"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/accent_blue"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Debt Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_card"
                android:padding="@dimen/padding_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BANK DEBT"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_micro"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvBankDebt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="@color/stock_red"
                    android:textSize="@dimen/text_size_headline"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accrues 0.2% interest per market tick"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_small"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etDebtAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Amount"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:background="@color/bg_surface"
                    android:padding="@dimen/padding_input"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnBorrow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BORROW"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@color/stock_red"
                        android:layout_marginEnd="4dp" />

                    <Button
                        android:id="@+id/btnRepay"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="REPAY"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@color/accent_blue"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- News / Events Feed Section -->
    <LinearLayout
        android:id="@+id/newsSection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/header_height"
        android:layout_marginBottom="@dimen/bottom_nav_height"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Section header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/bg_card"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MARKET NEWS"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_micro"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Events trigger every 3–5 updates"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_micro" />
        </LinearLayout>

        <!-- Empty state shown when no events have fired yet -->
        <TextView
            android:id="@+id/tvEmptyNews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No events yet.\nEvents will appear here as the market runs."
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_body_medium"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="60dp"
            android:padding="24dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEvents"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

    </LinearLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom"
        android:background="@color/bg_card"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:labelVisibilityMode="labeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

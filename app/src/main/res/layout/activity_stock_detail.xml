<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Stock Header Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_card"
            android:padding="@dimen/padding_header">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDetailSymbol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="APPL"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_headline"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AppleCore Technologies"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_body_small"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailSector"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Technology"
                        android:textColor="@color/accent_blue"
                        android:textSize="@dimen/text_size_small"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvDetailPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$182.50"
                        android:textColor="@color/stock_green"
                        android:textSize="@dimen/text_size_headline"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailChange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+1.20 (+0.66%)"
                        android:textColor="@color/stock_green"
                        android:textSize="@dimen/text_size_body_small"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDetailHighLow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H: $185.00  L: $179.00"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_small"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Price Chart -->
        <com.example.basicandroidapp.ui.PriceChartView
            android:id="@+id/priceChart"
            android:layout_width="match_parent"
            android:layout_height="@dimen/chart_height"
            android:background="@color/bg_surface"
            android:paddingLeft="8dp"
            android:paddingRight="8dp" />

        <!-- Holdings Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/bg_card"
            android:padding="@dimen/padding_card"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvOwnedShares"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Owned: 0 shares"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_body_small"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAvgBuy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avg Buy: —"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_caption"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvAvailableCash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cash: $10,000.00"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_body_small"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUnrealizedPnL"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P&amp;L: —"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_caption"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Transaction Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_card"
            android:padding="@dimen/padding_card"
            android:layout_marginTop="8dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Number of shares"
                app:boxBackgroundColor="@color/bg_surface"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/text_secondary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etQuantity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_title" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvTransactionSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter quantity to see cost"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/btnExecute"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_primary"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="BUY"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/stock_green"
                    style="@style/Widget.MaterialComponents.Button" />

                <Button
                    android:id="@+id/btnSell"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_primary"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="SELL"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/stock_red"
                    style="@style/Widget.MaterialComponents.Button" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnBuyAll"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_secondary"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="BUY ALL"
                    android:textSize="@dimen/text_size_body_small"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/stock_green"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/btnSellAll"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_secondary"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="SELL ALL"
                    android:textSize="@dimen/text_size_body_small"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/stock_red"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
